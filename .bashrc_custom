#!/bin/bash
# Custom bash configuration for devcontainer

# Make the shell prompt a green dollar sign followed by a space
export PS1="\[\033[1;32m\]$ \[\033[0m\]"

# Add a blank line before the prompt
export PS1="\n$PS1"

# Enhanced cd function: show directory stack in orange and list files
function cd {
    builtin cd "$@"
    printf "\033[38;5;208m"
    dirs
    printf "\033[0m"
    command ls -FN --color=auto
}

# Enhanced ls function: show directory stack in orange, then list files
function ls {
    printf "\033[38;5;208m"
    dirs
    printf "\033[0m"
    command ls -FN --color=auto "$@"
}

# Enable bash completion
source /usr/share/bash-completion/bash_completion

# Enable npm completion
source <(npm completion)

# Show current directory when opening the terminal
ls
